\ProvidesPackage{beamerouterthemehust}[HUST outer theme]
\RequirePackage{etoolbox} % Required for \BeforeBeginEnvironment

\mode<presentation>

% images
% 0.261 for 169, 0.282 for 43
% 0.4431 == 30/677,
% the relative left edge to the "one love one future" text
\newlength{\logoheight}
\setlength{\logoheight}{0.15\paperheight}
\pgfdeclareimage[height=\logoheight]{logo}{./viettel_logo.png}
\newcommand{\titlepagetextwidth}{0.8\paperwidth}
\pgfdeclareimage[width=0.261\paperwidth]{logo}{./viettel_logo.png}
\pgfdeclareimage[width=\paperwidth]{framebg}{./res/bg-169-4.png}
\pgfdeclareimage[width=\paperwidth]{thankframebg}{./res/bg-169-5.png}
\pgfdeclareimage[width=\paperwidth]{textslidebg}{./res/text-slide-169.png}
\pgfdeclareimage[width=\paperwidth]{imageslidebg}{./res/image-slide-169.png}
\pgfdeclareimage[width=\paperwidth]{textsubslidebg}{./res/text-slide-sub-169.png}

% --- 2. THE RESET HOOK ---
% This restores BOTH the background and the footline before every frame
\BeforeBeginEnvironment{frame}{%
	\setbeamertemplate{footline}[standard] % <-- Prevents [Title] from leaking
}

% --- GLOBAL TEMPLATE DEFINITIONS ---
% These stay outside the hook so Beamer can calculate their dimensions properly

% --- HEADER STRIP ---
% Define the background color for the strip (uses your existing 'hustred' color)
\setbeamercolor{headerstrip}{bg=hustred}

\setbeamertemplate{headline}{%
  \nointerlineskip % Prevents a white gap at the very top of the slide
  \begin{beamercolorbox}[wd=\paperwidth, ht=1cm, dp=0cm]{headerstrip}
    % Leave this environment empty to keep it as a solid decorative line.
    % If you want to add a logo or text to the top strip later, put it here.
  \end{beamercolorbox}%
}

\makeatletter
\setbeamertemplate{frametitle}{%
	\vspace*{-1.25cm} % <-- Adjust vertical position of the main title
	{\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle\par}%
	% Conditionally add the subtitle if it exists
	\ifx\insertframesubtitle\@empty\else
		\vspace*{0.38cm} % <-- Adjust spacing between title and subtitle
		{\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\insertframesubtitle\par}%
	\fi
}
\makeatother

\setbeamertemplate{navigation symbols}{%
  \usebeamerfont{footline}%
  \textcolor{hustred}{\insertframenumber}%
  \hspace{1.5em}%
}

\defbeamertemplate*{footline}{standard}{}


\makeatletter
\define@key{beamerframe}{Title}[true]{
    \setbeamertemplate{background canvas}[Title]
    \setkeys{beamerframe}{plain}%
}
\define@key{beamerframe}{Image}[true]{
	\setbeamertemplate{background canvas}{\pgfuseimage{imageslidebg}}
}
% --- NEW ---
\define@key{beamerframe}{Subtitle}[true]{
	\setbeamertemplate{background canvas}{\pgfuseimage{textsubslidebg}}
}
\makeatother


% --- TITLE PAGE TEMPLATE ---
\setbeamertemplate{title page}{	
	\nointerlineskip
	\newlength{\titlepad}
	\setlength{\titlepad}{0.15\paperwidth}
	\newlength{\titleareaheight}
	\newlength{\titleareawidth}
	\newlength{\titleareadepth}
	\setlength{\titleareaheight}{\textheight}
	\setlength{\titleareawidth}{\textwidth}
	\parbox[t][\titleareaheight]{\titleareawidth}{%
      \begin{center}
		\vfill
		\begin{beamercolorbox}[wd=\titleareawidth]{title}
			\usebeamerfont{title}\inserttitle
		\end{beamercolorbox}
        \smallskip
		\ifx\insertsubtitle\empty\relax\else
			\begin{beamercolorbox}[wd=\titleareawidth]{subtitle}
				\usebeamerfont{subtitle}\insertsubtitle
			\end{beamercolorbox}
		\fi
		\vfill
		\begin{beamercolorbox}[wd=\titleareawidth]{author}
			\usebeamerfont{author}\insertauthor
		\end{beamercolorbox}
		\smallskip
		\begin{beamercolorbox}[wd=\titleareawidth]{author}
			\usebeamerfont{date}\insertdate
		\end{beamercolorbox}
		\vfill
		{\scriptsize Source: \href{https://github.com/tuasananh/flow-table}{\texttt{https://github.com/tuasananh/flow-table}}}
		\vspace*{0.2cm}
      \end{center}
	}
}


\mode<all>
