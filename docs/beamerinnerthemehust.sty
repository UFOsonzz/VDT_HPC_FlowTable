\ProvidesPackage{beamerinnerthemehust}[HUST inner theme]

\mode<presentation>
\setbeamertemplate{caption}[numbered]

\setbeamertemplate{itemize item}{%
	\large\usebeamercolor[fg]{item}{\(\diamond\)}%
}
\setbeamertemplate{itemize subitem}{%
	\large\usebeamercolor[fg]{item}{\(\circ\)}%
}
\setbeamertemplate{itemize subsubitem}{%
	\large\usebeamercolor[fg]{item}{\(\star\)}%
}

\mode<all>

